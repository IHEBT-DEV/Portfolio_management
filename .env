# ==============================================================================
# Portfolio Management System Configuration Variables Environment Template
# Copy this file to a local secure file named '.env' and populate variables.
# ==============================================================================

# Global Infrastructure Environment Mode (development / staging / production)
ENV_MODE=production
LOG_LEVEL=INFO

# Synchronous REST Core Server Binding Port Parameters
PORT=5000

# Mongo DB Polyglot NoSQL Document Store Credentials
MONGO_URI=mongodb://admin_user:secure_password_string@mongo_host:27017/
MONGO_DATABASE=portfolio_management_db

# Redis High-Concurrency In-Memory Memory Store Cache State Credentials
REDIS_HOST=redis_cache_cluster
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=high_entropy_cache_password_token

# External Market API Endpoint Keys Fallback Configuration Mappings
COINGECKO_API_KEY=your_optional_premium_coingecko_token_here
